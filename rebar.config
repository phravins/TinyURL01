{erl_opts, [debug_info]}.

{deps, [
    {cowboy, "2.10.0"},
    {jsone, "1.8.0"},
    {epgsql, "4.7.1"},
    {poolboy, "1.5.2"}
]}.

{relx, [{release, {shortener_release, "0.1.0"},
         [shortener_api,
          shortener_core,
          shortener_storage,
          shortener_analytics,
          sasl]},

        {sys_config, "./config/sys.config"},
        {vm_args, "./config/vm.args"},

        {dev_mode, true},
        {include_erts, false},

        {extended_start_script, true}]
}.

{profiles, [{prod, [{relx, [{dev_mode, false},
                            {include_erts, true}]}]
            }]
}.
