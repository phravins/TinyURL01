#!/usr/bin/env escript
%% -*- erlang -*-
%%
%% shortener_cli v2.1.0 — Cross-platform CLI for URL Shortener
%%
-mode(compile).

-define(VERSION, "2.1.0").
-define(GITHUB_RAW,
    "https://raw.githubusercontent.com/phravins/TinyURL01/main/cli/shortener_cli").

%% =============================================================================
%% Entry Point
%% =============================================================================

main([])             -> print_help(), halt(0);
main(["help"   | _]) -> print_help(), halt(0);
main(["--help" | _]) -> print_help(), halt(0);
main(["version"])    -> print_version(), halt(0);
main(["--version"])  -> print_version(), halt(0);
main(["update"])     -> do_update();

%% ---- Config ----
main(["config", "set"]) ->
    err_msg("Usage: " ++ cy() ++ "config set --host HOST --port PORT [--token TOKEN]\n" ++
            "            [--db-host H] [--db-port P] [--db-user U] [--db-pass P] [--db-name N]" ++ r());
main(["config", "set" | Args]) ->
    case parse_config_flags(Args, default_config()) of
        {error, Reason} -> err_msg(Reason);
        Cfg ->
            save_config(Cfg),
            ok_msg("Config saved  " ++ cy() ++ "~s:~w" ++ r(),
                   [maps:get(host, Cfg), maps:get(port, Cfg)])
    end;
main(["config", "show"]) ->
    print_config(load_config());
main(["config" | Sub]) ->
    err_msg("Unknown config subcommand: " ++ string:join(Sub, " ") ++
            "\n     Use: " ++ cy() ++ "config set" ++ r() ++ " or " ++ cy() ++ "config show" ++ r());

%% ---- Shorten ----
main(["shorten"]) ->
    err_msg("Usage: " ++ cy() ++ "shortener shorten <url> [--custom CODE] [--ttl SEC]" ++ r());
main(["shorten", Url | Opts]) ->
    case validate_url(Url) of
        {error, Msg} -> err_msg(Msg);
        ok ->
            Cfg   = load_config(),
            Flags = parse_shorten_flags(Opts),
            case validate_shorten_flags(Flags) of
                {error, Msg} -> err_msg(Msg);
                ok ->
                    working("Shortening URL"),
                    case post(Cfg, "/api/shorten", build_shorten_body(Url, Flags)) of
                        {ok, #{<<"short_url">> := Short} = Resp} ->
                            print_shorten_result(Short, Resp);
                        {error, M} -> err_msg(M)
                    end
            end
    end;

%% ---- Bulk ----
main(["bulk"]) ->
    err_msg("Usage: " ++ cy() ++ "shortener bulk <url1> <url2> ..." ++ r());
main(["bulk" | Urls]) ->
    Bad = [U || U <- Urls, validate_url(U) =/= ok],
    case Bad of
        [_|_] ->
            err_msg("Invalid URLs (must start with http:// or https://):\n" ++
                    lists:concat(["     " ++ U ++ "\n" || U <- Bad]));
        [] ->
            Cfg  = load_config(),
            Body = jsone_encode(#{<<"urls">> => [list_to_binary(U) || U <- Urls]}),
            working(lists:flatten(io_lib:format("Shortening ~w URLs", [length(Urls)]))),
            case post(Cfg, "/api/shorten", Body) of
                {ok, #{<<"results">> := Results}} -> print_bulk_results(Results);
                {error, M} -> err_msg(M)
            end
    end;

