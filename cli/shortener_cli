help_cmd(Cmd, Opts, Desc) ->
    Full = case Opts of "" -> Cmd; _ -> Cmd ++ " " ++ Opts end,
    io:format("    ~s~s~s  ~s~s~s~n",
              [cy(), pad_to(Full, 50), r(), dm(), Desc, r()]).

print_shorten_result(Short, Resp) ->
    io:format("~n  ~s✓~s  ~s~s~ts~s~n", [g(), r(), b(), cy(), Short, r()]),
    case maps:get(<<"expires_at">>, Resp, null) of
        null -> ok;
        Exp  -> io:format("  ~s   Expires~s    ~ts~n", [dm(), r(), Exp])
    end,
    case maps:get(<<"protected">>, Resp, false) of
        true -> io:format("  ~s   Protected~s  yes~n", [dm(), r()]);
        _    -> ok
    end,
    io:format("~n").

print_bulk_results(Results) ->
    Good = length([R || R <- Results, maps:get(<<"short_url">>, R, null) =/= null]),
    Bad  = length(Results) - Good,
    BCol = if Bad > 0 -> e(); true -> dm() end,
    io:format("~n  ~s~w shortened~s  ~s~w failed~s~n~n",
              [g(), Good, r(), BCol, Bad, r()]),
    lists:foreach(fun(R) ->
        Url   = maps:get(<<"url">>,       R, <<"?">>),
        Short = maps:get(<<"short_url">>, R, null),
        Err   = maps:get(<<"error">>,     R, <<"unknown error">>),
        case Short of
            null ->
                io:format("  ~s✗~s  ~ts~n     ~s~ts~s~n",
                          [e(), r(), Url, dm(), Err, r()]);
            _ ->
                io:format("  ~s✓~s  ~ts~n     ~s~s~ts~s~n",
                          [g(), r(), Url, cy(), b(), Short, r()])
        end
    end, Results),
    io:format("~n").

