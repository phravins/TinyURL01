%% ---- Admin API ----
main(["admin"]) ->
    err_msg("admin requires a subcommand: " ++ cy() ++
            "stats | list | delete <code> | analytics <code>" ++ r());
main(["admin", "stats"]) ->
    Cfg = load_config(),
    warn_default_token(Cfg),
    case admin_get(Cfg, "/api/admin/stats") of
        {ok, R}      -> print_admin_stats(R);
        {error, Msg} -> err_msg(Msg)
    end;
main(["admin", "list" | Opts]) ->
    Cfg   = load_config(),
    warn_default_token(Cfg),
    Flags = parse_page_flags(Opts),
    Page  = maps:get(page,  Flags, 1),
    Limit = maps:get(limit, Flags, 10),
    Path  = lists:flatten(io_lib:format("/api/admin/urls?page=~w&limit=~w", [Page, Limit])),
    case admin_get(Cfg, Path) of
        {ok, #{<<"urls">> := Urls}} -> print_admin_list(Urls, Page);
        {error, Msg}                -> err_msg(Msg)
    end;
main(["admin", "delete"]) ->
    err_msg("Usage: " ++ cy() ++ "shortener admin delete <code>" ++ r());
main(["admin", "delete", Code]) ->
    case validate_code(Code) of
        {error, Msg} -> err_msg(Msg);
        ok ->
            Cfg = load_config(),
            warn_default_token(Cfg),
            case admin_delete(Cfg, "/api/admin/urls/" ++ Code) of
                {ok, _}      -> ok_msg("Deleted " ++ cy() ++ "~s" ++ r(), [Code]);
                {error, Msg} -> err_msg(Msg)
            end
    end;
main(["admin", "analytics"]) ->
    err_msg("Usage: " ++ cy() ++ "shortener admin analytics <code>" ++ r());
main(["admin", "analytics", Code]) ->
    case validate_code(Code) of
        {error, Msg} -> err_msg(Msg);
        ok ->
            Cfg = load_config(),
            warn_default_token(Cfg),
            case admin_get(Cfg, "/api/admin/analytics/" ++ Code) of
