print_admin_list(Urls, Page) ->
    io:format("~n  ~s~sPage ~w~s  ~s~w results~s~n~n",
              [b(), cy(), Page, r(), dm(), length(Urls), r()]),
    Hdr = pad_to("Code", 14) ++ pad_to("Long URL", 33) ++
