          "FROM urls WHERE long_url ILIKE '%" ++ Escaped ++ "%' "
          "OR short_code ILIKE '%" ++ Escaped ++ "%' "
          "ORDER BY click_count DESC LIMIT 30;",
    case check_psql() of
        {error, Msg} -> err_msg(Msg);
        ok ->
            case run_psql_query(Cfg, SQL) of
                {ok, Text} ->
                    io:format("~n  ~s~sSearch:~s ~s~s~s~n~n",
