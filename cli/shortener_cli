print_analytics(Events, Code) ->
    io:format("~n  ~s~sAnalytics:~s ~s~s~s  ~s~w events~s~n~n",
              [b(), cy(), r(), b(), Code, r(), dm(), length(Events), r()]),
    Hdr = pad_to("IP", 18) ++ pad_to("CC", 7) ++
          pad_to("City", 18) ++ "Clicked At",
    io:format("  ~s~s~s~n", [dm(), Hdr, r()]),
    io:format("  ~s~s~s~n", [dm(), string:copies("-", 60), r()]),
    lists:foreach(fun(E) ->
        IP      = bin_str(maps:get(<<"ip">>,         E, null)),
        Country = bin_str(maps:get(<<"country">>,    E, null)),
        City    = bin_str(maps:get(<<"city">>,       E, null)),
        At      = bin_str(maps:get(<<"clicked_at">>, E, null)),
        io:format("  ~s~n",
            [pad_to(IP, 18) ++ pad_to(Country, 7) ++ pad_to(City, 18) ++ At])
    end, Events),
    io:format("~n").

print_config(Cfg) ->
    io:format("~n  ~s~sAPI~s~n", [b(), cy(), r()]),
    lbl("Host",  maps:get(host,  Cfg, "localhost")),
    lbl("Port",  maps:get(port,  Cfg, 8080)),
    Token = maps:get(token, Cfg, ""),
    Masked = case Token of
        "change_me_in_production" ->
            dm() ++ "(default -- not configured)" ++ r();
        T ->
            Len = length(T),
            if Len > 8 -> string:substr(T, 1, 4) ++ string:copies("*", Len - 4);
               true    -> string:copies("*", Len)
            end
    end,
    io:format("  ~s~-16s~s ~ts~n", [dm(), "Token", r(), Masked]),
    io:format("~n  ~s~sDatabase~s~n", [b(), cy(), r()]),
    lbl("DB Host", maps:get(db_host, Cfg, "localhost")),
    lbl("DB Port", maps:get(db_port, Cfg, 5432)),
    lbl("DB User", maps:get(db_user, Cfg, "postgres")),
    lbl("DB Name", maps:get(db_name, Cfg, "shortener")),
    Pass = maps:get(db_pass, Cfg, ""),
    io:format("  ~s~-16s~s ~s~n",
              [dm(), "DB Pass", r(), string:copies("*", length(Pass))]),
    io:format("~n  ~sFile: ~s~s~n~n", [dm(), config_path(), r()]).
