    io:format("~n  ~s~sDB Commands~s  ~s~s:~w~s~n~n",
              [b(), cy(), r(), dm(), db_host(Cfg), db_port(Cfg), r()]),
    help_cmd("db status",               "",                  "Check DB connection"),
    help_cmd("db stats",                "",                  "Tables & row counts"),
    help_cmd("db urls",                 "[--limit N]",       "List URLs from DB"),
    help_cmd("db analytics",            "[--code C] [--limit N]", "Click events"),
    help_cmd("db search <term>",        "",                  "Search URLs by keyword"),
    help_cmd("db shell",                "",                  "Open psql session"),
    help_cmd("db query \"<SQL>\"",      "",                  "Run raw SQL"),
    help_cmd("db config set",           "--db-host H ...",   "Save DB connection"),
    io:format("~n");

main(["db", "status"]) ->
    Cfg = load_config(),
    case check_psql() of
        {error, Msg} -> err_msg(Msg);
        ok ->
            io:format("~n  ~s⋯~s  Connecting to ~s~s:~w~s ...~n",
                      [dm(), r(), cy(), db_host(Cfg), db_port(Cfg), r()]),
            Out = run_psql_query(Cfg, "SELECT version();"),
            case Out of
                {error, E} -> err_msg(E);
                {ok, Text} ->
