main(["db", "stats"]) ->
    Cfg = load_config(),
    case check_psql() of
        {error, Msg} -> err_msg(Msg);
        ok ->
            SQL = "SELECT "
                  "'URLs'       AS table_name, COUNT(*)::text AS rows FROM urls "
                  "UNION ALL SELECT "
                  "'analytics'  AS table_name, COUNT(*)::text AS rows FROM analytics "
                  "UNION ALL SELECT "
                  "'url_meta'   AS table_name, COUNT(*)::text AS rows FROM url_meta;"
                  " SELECT (SELECT COALESCE(SUM(click_count),0) FROM urls) AS total_clicks,"
                  "        (SELECT COUNT(*) FROM urls WHERE created_at >= CURRENT_DATE) AS new_today,"
                  "        (SELECT short_code FROM urls ORDER BY click_count DESC LIMIT 1) AS top_code;",
            case run_psql_query(Cfg, SQL) of
                {ok, Text} ->
                    io:format("~n  ~s~sDatabase Stats~s  ~s~s:~w/~s~s~n~n",
                              [b(), cy(), r(), dm(), db_host(Cfg), db_port(Cfg), db_name(Cfg), r()]),
                    io:format("~s~n~n", [Text]);
                {error, E} -> err_msg(E)
            end
    end;

main(["db", "urls" | Opts]) ->
    Cfg   = load_config(),
    Flags = parse_db_flags(Opts),
    Limit = integer_to_list(maps:get(limit, Flags, 20)),
    SQL = "SELECT short_code, substring(long_url,1,50) AS url, "
          "click_count, created_at::date AS created, "
          "COALESCE(expires_at::text,'--') AS expires "
          "FROM urls ORDER BY id DESC LIMIT " ++ Limit ++ ";",
    case check_psql() of
        {error, Msg} -> err_msg(Msg);
        ok ->
            case run_psql_query(Cfg, SQL) of
                {ok, Text} ->
                    io:format("~n  ~s~sURLs~s ~s(latest ~s)~s~n~n",
                              [b(), cy(), r(), dm(), Limit, r()]),
                    io:format("~s~n~n", [Text]);
                {error, E} -> err_msg(E)
            end
    end;

main(["db", "analytics" | Opts]) ->
    Cfg   = load_config(),
    Flags = parse_db_flags(Opts),
    Limit = integer_to_list(maps:get(limit, Flags, 20)),
    Where = case maps:get(code, Flags, undefined) of
        undefined -> "";
        Code      -> " WHERE short_code = '" ++ Code ++ "'"
    end,
    SQL = "SELECT short_code, ip_address, country, city, "
          "clicked_at::timestamp(0) AS at "
          "FROM analytics" ++ Where ++
          " ORDER BY clicked_at DESC LIMIT " ++ Limit ++ ";",
    case check_psql() of
        {error, Msg} -> err_msg(Msg);
        ok ->
            case run_psql_query(Cfg, SQL) of
                {ok, Text} ->
                    io:format("~n  ~s~sAnalytics~s ~s(latest ~s)~s~n~n",
                              [b(), cy(), r(), dm(), Limit, r()]),
                    io:format("~s~n~n", [Text]);
                {error, E} -> err_msg(E)
            end
    end;

