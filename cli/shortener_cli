%% =============================================================================
%% Auto-Update
%% =============================================================================

do_update() ->
    io:format("~n  ~s↑~s  Checking for updates  " ++ dm() ++ "(current: v~s)" ++ r() ++ "~n",
              [cy(), r(), ?VERSION]),
    case download_file(?GITHUB_RAW) of
        {ok, Content} ->
            NewVer = extract_version(Content),
            case compare_versions(NewVer, ?VERSION) of
                newer ->
                    io:format("  ~s✦~s  New version: " ++ g() ++ "v~s" ++ r() ++ "~n",
                              [y(), r(), NewVer]),
                    write_update(Content, NewVer);
                same ->
                    io:format("  ~s✓~s  Already up to date " ++ cy() ++
                              "(v~s)" ++ r() ++ "~n~n", [g(), r(), ?VERSION]);
                older ->
                    io:format("  ~s~s  Local v~s is ahead of remote v~s~s~n~n",
                              [dm(), r(), ?VERSION, NewVer, r()])
            end;
        {error, Msg} ->
            err_msg("Update check failed: " ++ Msg)
    end.

write_update(Content, NewVer) ->
    Script = escript:script_name(),
    io:format("  ~s↓~s  Writing update to ~s~s~s ...~n", [cy(), r(), b(), Script, r()]),
    case file:write_file(Script, Content) of
        ok ->
            case os:type() of
                {unix, _} -> os:cmd("chmod +x \"" ++ Script ++ "\"");
                _         -> ok
            end,
            ok_msg("Updated to " ++ g() ++ "v~s" ++ r() ++ "  Restart your terminal to apply.",
                   [NewVer]);
        {error, eacces} ->
            err_msg("Permission denied — try running as administrator / sudo");
        {error, Reason} ->
            err_msg(lists:flatten(io_lib:format("Write failed: ~p", [Reason])))
    end.

extract_version(Content) ->
    Bin = if is_binary(Content) -> binary_to_list(Content); true -> Content end,
    case re:run(Bin, "-define\\(VERSION,\\s*\"([0-9]+\\.[0-9]+\\.[0-9]+)\"\\)",
                [{capture, [1], list}]) of
        {match, [V]} -> V;
        nomatch      -> "0.0.0"
    end.

compare_versions(A, B) ->
    try
        AP = [list_to_integer(X) || X <- string:split(A, ".", all)],
        BP = [list_to_integer(X) || X <- string:split(B, ".", all)],
        if AP > BP -> newer; AP < BP -> older; true -> same end
    catch _:_ -> same
    end.

download_file(Url) ->
    inets:start(),
    ssl:start(),
    Opts = [{timeout, 20000}, {connect_timeout, 8000}],
    UA   = [{"User-Agent", "shortener-cli/" ++ ?VERSION}],
    case httpc:request(get, {Url, UA}, Opts, []) of
        {ok, {{_, 200, _}, _, Body}} -> {ok, Body};
        {ok, {{_, Status, _}, _, _}} ->
            {error, lists:flatten(io_lib:format("HTTP ~w from GitHub", [Status]))};
        {error, {failed_connect, _}} ->
            {error, "Cannot reach GitHub — check internet connection"};
        {error, Reason} ->
            {error, lists:flatten(io_lib:format("~p", [Reason]))}
    end.

%% =============================================================================
%% PostgreSQL Helpers
%% =============================================================================

check_psql() ->
    Result = string:trim(os:cmd("psql --version 2>&1")),
    case Result of
        "psql" ++ _ -> ok;
        _ ->
            {error, "psql not found in PATH\n" ++
                    "     Install PostgreSQL client tools:\n" ++
                    "       Windows: https://www.postgresql.org/download/windows/\n" ++
                    "       macOS:   brew install libpq\n" ++
                    "       Linux:   sudo apt install postgresql-client"}
    end.

run_psql_query(Cfg, SQL) ->
    os:putenv("PGPASSWORD", db_pass(Cfg)),
    Safe = re:replace(SQL, "\"", "\\\\\"", [global, {return, list}]),
    Cmd  = lists:flatten(io_lib:format(
        "psql -h ~s -p ~w -U ~s -d ~s -c \"~s\" 2>&1",
        [db_host(Cfg), db_port(Cfg), db_user(Cfg), db_name(Cfg), Safe])),
    Output = string:trim(os:cmd(Cmd)),
    case Output of
        "psql: error" ++ _ ->
            {error, "psql error: " ++ Output};
        "psql: fatal" ++ _ ->
            {error, "DB connection failed: " ++ Output};
        "ERROR:" ++ _ ->
            {error, "SQL error: " ++ Output};
        _ ->
            {ok, Output}
    end.

open_db_shell(Cfg) ->
    Host = db_host(Cfg),
    Port = integer_to_list(db_port(Cfg)),
    User = db_user(Cfg),
    Name = db_name(Cfg),
    ConnCmd = lists:flatten(io_lib:format(
        "psql -h ~s -p ~s -U ~s -d ~s", [Host, Port, User, Name])),
    io:format("~n  ~s~spsql session~s  ~s~s:~s/~s~s~n~n",
              [b(), cy(), r(), dm(), Host, Port, Name, r()]),
    io:format("  Run this command in your terminal:~n~n"),
    io:format("    ~s~s~s~n~n", [cy(), ConnCmd, r()]),
    io:format("  ~s(Set PGPASSWORD=~s before running if password is required)~s~n~n",
              [dm(), db_pass(Cfg), r()]),
    case os:type() of
        {win32, _} ->
            SetPwd = "set PGPASSWORD=" ++ db_pass(Cfg) ++ " && " ++ ConnCmd,
            os:cmd("start cmd /k \"" ++ SetPwd ++ "\""),
            info_msg("Opened a new cmd window with psql", []);
        _ ->
            ok
    end.

db_host(Cfg) -> maps:get(db_host, Cfg, "localhost").
db_port(Cfg) -> maps:get(db_port, Cfg, 5432).
db_user(Cfg) -> maps:get(db_user, Cfg, "postgres").
db_pass(Cfg) -> maps:get(db_pass, Cfg, "postgres").
db_name(Cfg) -> maps:get(db_name, Cfg, "shortener").

%% =============================================================================
%% Server Check
%% =============================================================================

check_server(Cfg) ->
    inets:start(),
    Url  = base_url(Cfg),
    Opts = [{timeout, 2000}, {connect_timeout, 1500}],
    case httpc:request(get, {Url, []}, Opts, []) of
        {ok, _} -> ok;
        _       -> {error, unreachable}
    end.

%% =============================================================================
%% Validation
%% =============================================================================

validate_url("") ->
    {error, "URL cannot be empty"};
validate_url("http://" ++ [_|_])  -> ok;
validate_url("https://" ++ [_|_]) -> ok;
validate_url(Url) ->
    {error, "URL must start with " ++ cy() ++ "http://" ++ r() ++ " or " ++
            cy() ++ "https://" ++ r() ++ "\n     Got: " ++ Url}.

validate_code("") ->
    {error, "Short code cannot be empty"};
validate_code(Code) ->
    case re:run(Code, "^[a-zA-Z0-9_-]+$") of
        {match, _} -> ok;
        nomatch    ->
            {error, "Invalid code — use only letters, numbers, - and _"}
    end.

validate_shorten_flags(Flags) ->
    case maps:get(ttl, Flags, undefined) of
        undefined            -> ok;
        N when is_integer(N), N > 0 -> ok;
        _ -> {error, "--ttl must be a positive integer (seconds)"}
    end.

warn_default_token(Cfg) ->
    case maps:get(token, Cfg, "change_me_in_production") of
        "change_me_in_production" ->
            io:format("  ~s!~s  Using default token — set with: ~s~n~n",
                      [y(), r(),
                       cy() ++ "shortener config set --token YOUR_TOKEN" ++ r()]);
        _ -> ok
    end.

%% =============================================================================
%% HTTP Helpers
%% =============================================================================

post(Cfg, Path, Body) ->
    http_req(post, base_url(Cfg) ++ Path,
             [{"Content-Type", "application/json"}], Body).

get_req(Cfg, Path) ->
    http_req(get, base_url(Cfg) ++ Path, [], "").

admin_get(Cfg, Path) ->
    Token = maps:get(token, Cfg, ""),
    http_req(get, base_url(Cfg) ++ Path, [{"X-Admin-Token", Token}], "").

admin_delete(Cfg, Path) ->
    Token = maps:get(token, Cfg, ""),
    http_req(delete, base_url(Cfg) ++ Path, [{"X-Admin-Token", Token}], "").

http_req(Method, Url, Headers, Body) ->
    inets:start(),
    ssl:start(),
    Request = case Method of
        post   -> {Url, Headers, "application/json", Body};
        get    -> {Url, Headers};
        delete -> {Url, Headers}
    end,
    Opts = [{timeout, 10000}, {connect_timeout, 5000}],
    case httpc:request(Method, Request, Opts, []) of
        {ok, {{_, Status, _}, _, RespBody}} ->
            decode_response(Status, list_to_binary(RespBody));
        {error, {failed_connect, _}} ->
            Cfg = load_config(),
            {error, "Cannot connect to " ++ base_url(Cfg) ++
                    "\n     Is the server running?  Start it: " ++
                    cy() ++ "shortener start" ++ r()};
        {error, timeout} ->
            {error, "Request timed out (10s) — server may be overloaded"};
        {error, Reason} ->
            {error, lists:flatten(io_lib:format("HTTP error: ~p", [Reason]))}
    end.

decode_response(Status, Body) ->
    case jsone_decode(Body) of
        {ok, Decoded} ->
            if Status >= 200, Status < 300 ->
                    {ok, Decoded};
               Status =:= 400 ->
                    Err = maps:get(<<"error">>, Decoded, <<"Bad request">>),
                    {error, binary_to_list(Err)};
               Status =:= 401 ->
                    {error, "Unauthorized — set token: " ++ cy() ++
                            "shortener config set --token TOKEN" ++ r()};
               Status =:= 403 ->
                    {error, "Forbidden — wrong password or insufficient permissions"};
               Status =:= 404 ->
                    {error, "Not found — check the short code is correct"};
               Status =:= 409 ->
                    {error, "Conflict — code already taken, try a different " ++
                            cy() ++ "--custom CODE" ++ r()};
               Status =:= 422 ->
                    Err = maps:get(<<"error">>, Decoded, <<"Unprocessable entity">>),
                    {error, binary_to_list(Err)};
               Status =:= 429 ->
                    {error, "Rate limited — slow down and try again shortly"};
               Status >= 500 ->
                    {error, lists:flatten(
                        io_lib:format("Server error (~w) — check server logs", [Status]))};
               true ->
                    Err = maps:get(<<"error">>, Decoded, <<"Unknown error">>),
                    {error, binary_to_list(Err)}
            end;
        {error, _} ->
            {error, lists:flatten(io_lib:format(
                "Unexpected response (HTTP ~w) — is this a shortener server?", [Status]))}
    end.

%% =============================================================================
%% JSON Helpers
%% =============================================================================

jsone_decode(Bin) ->
    try
        case code:ensure_loaded(jsone) of
            {module, jsone} -> {ok, jsone:decode(Bin)};
            _               -> simple_json_decode(Bin)
        end
    catch _:_ ->
        simple_json_decode(Bin)
    end.

jsone_encode(Map) ->
    case code:ensure_loaded(jsone) of
        {module, jsone} -> binary_to_list(jsone:encode(Map));
        _               -> simple_json_encode(Map)
    end.

simple_json_decode(Bin) ->
    try
        {ok, parse_json_object(string:trim(binary_to_list(Bin)))}
    catch _:_ ->
        {error, bad_json}
    end.

parse_json_object("{" ++ Rest)  -> parse_pairs(Rest, #{});
parse_json_object("[" ++ Rest)  -> parse_array(Rest, []);
parse_json_object("\"" ++ Rest) -> {Val, _} = parse_string(Rest), Val;
parse_json_object("null"  ++ _) -> null;
parse_json_object("true"  ++ _) -> true;
parse_json_object("false" ++ _) -> false;
parse_json_object(S) ->
    {match, [N]} = re:run(S, "^-?[0-9]+", [{capture, all, list}]),
    list_to_integer(N).

parse_pairs("}" ++ _, Map) -> Map;
parse_pairs(S, Map) ->
    S1 = skip_ws(S),
    {Key, S2} = case S1 of
        "\"" ++ R -> parse_string(R);
        _         -> {<<"">>, S1}
    end,
    S3 = skip_ws(skip_char($:, skip_ws(S2))),
    {Val, S4} = parse_value(S3),
    S5 = skip_ws(skip_optional_comma(S4)),
    parse_pairs(S5, Map#{Key => Val}).

parse_array("]" ++ _, Acc) -> lists:reverse(Acc);
parse_array(S, Acc) ->
    S1 = skip_ws(S),
    {Val, S2} = parse_value(S1),
    S3 = skip_ws(skip_optional_comma(S2)),
    parse_array(S3, [Val | Acc]).

parse_value("\"" ++ R)    -> parse_string(R);
parse_value("{" ++ R)     -> {parse_pairs(R, #{}), ""};
parse_value("[" ++ R)     -> {parse_array(R, []), ""};
parse_value("null"  ++ R) -> {null,  R};
parse_value("true"  ++ R) -> {true,  R};
parse_value("false" ++ R) -> {false, R};
parse_value(S) ->
    {match, [{0, L}]} = re:run(S, "^-?[0-9]+", [{capture, first, index}]),
    {list_to_integer(string:substr(S, 1, L)), string:substr(S, L+1)}.

parse_string(S) -> parse_string(S, []).
parse_string("\"" ++ R, Acc)       -> {list_to_binary(lists:reverse(Acc)), R};
parse_string("\\" ++ [C | R], Acc) -> parse_string(R, [C | Acc]);
parse_string([C | R], Acc)         -> parse_string(R, [C | Acc]).

skip_ws([$ |R])  -> skip_ws(R);
skip_ws([$\n|R]) -> skip_ws(R);
skip_ws([$\r|R]) -> skip_ws(R);
skip_ws([$\t|R]) -> skip_ws(R);
skip_ws(S)       -> S.

skip_char(C, [C|R]) -> R;
skip_char(_, S)     -> S.

skip_optional_comma([$,|R]) -> R;
skip_optional_comma(S)      -> S.

simple_json_encode(Map) when is_map(Map) ->
    Pairs = maps:fold(fun(K, V, Acc) ->
        [lists:flatten(io_lib:format("\"~ts\": ~s", [K, simple_json_encode(V)])) | Acc]
    end, [], Map),
    "{" ++ string:join(Pairs, ", ") ++ "}";
simple_json_encode(List) when is_list(List) ->
    "[" ++ string:join([simple_json_encode(I) || I <- List], ", ") ++ "]";
simple_json_encode(B) when is_binary(B)  -> "\"" ++ binary_to_list(B) ++ "\"";
simple_json_encode(I) when is_integer(I) -> integer_to_list(I);
simple_json_encode(true)  -> "true";
simple_json_encode(false) -> "false";
simple_json_encode(null)  -> "null".

%% =============================================================================
%% Config
%% =============================================================================

config_path() ->
    Home = case os:getenv("HOME") of
        false ->
            case os:getenv("USERPROFILE") of
                false -> ".";
                P     -> P
            end;
        H -> H
    end,
    filename:join(Home, ".shortener.conf").

default_config() ->
    #{host    => "localhost",
      port    => 8080,
      token   => "change_me_in_production",
      db_host => "localhost",
      db_port => 5432,
      db_user => "postgres",
      db_pass => "postgres",
      db_name => "shortener"}.

load_config() ->
    case file:consult(config_path()) of
        {ok, [Terms]} ->
            #{host    => proplists:get_value(host,    Terms, "localhost"),
              port    => proplists:get_value(port,    Terms, 8080),
              token   => proplists:get_value(token,   Terms, "change_me_in_production"),
              db_host => proplists:get_value(db_host, Terms, "localhost"),
              db_port => proplists:get_value(db_port, Terms, 5432),
              db_user => proplists:get_value(db_user, Terms, "postgres"),
              db_pass => proplists:get_value(db_pass, Terms, "postgres"),
              db_name => proplists:get_value(db_name, Terms, "shortener")};
        _ ->
            default_config()
    end.

save_config(#{host := Host, port := Port, token := Token,
              db_host := DbHost, db_port := DbPort,
              db_user := DbUser, db_pass := DbPass, db_name := DbName}) ->
    Terms = io_lib:format(
        "[{host,~p},{port,~w},{token,~p},"
        "{db_host,~p},{db_port,~w},{db_user,~p},{db_pass,~p},{db_name,~p}].~n",
        [Host, Port, Token, DbHost, DbPort, DbUser, DbPass, DbName]),
    file:write_file(config_path(), Terms).

parse_config_flags([], Cfg) -> Cfg;
parse_config_flags(["--host",    H | R], Cfg) -> parse_config_flags(R, Cfg#{host    => H});
parse_config_flags(["--token",   T | R], Cfg) -> parse_config_flags(R, Cfg#{token   => T});
parse_config_flags(["--db-host", H | R], Cfg) -> parse_config_flags(R, Cfg#{db_host => H});
parse_config_flags(["--db-user", U | R], Cfg) -> parse_config_flags(R, Cfg#{db_user => U});
parse_config_flags(["--db-pass", P | R], Cfg) -> parse_config_flags(R, Cfg#{db_pass => P});
parse_config_flags(["--db-name", N | R], Cfg) -> parse_config_flags(R, Cfg#{db_name => N});
parse_config_flags(["--port", P | R], Cfg) ->
    case catch list_to_integer(P) of
        {'EXIT', _}           -> {error, "--port must be a number, got: " ++ P};
        N when N < 1; N > 65535 -> {error, "--port must be 1–65535"};
        N -> parse_config_flags(R, Cfg#{port => N})
    end;
parse_config_flags(["--db-port", P | R], Cfg) ->
    case catch list_to_integer(P) of
        {'EXIT', _}           -> {error, "--db-port must be a number, got: " ++ P};
        N when N < 1; N > 65535 -> {error, "--db-port must be 1–65535"};
        N -> parse_config_flags(R, Cfg#{db_port => N})
    end;
parse_config_flags([U | R], Cfg) ->
    io:format("  ~s!~s  Unknown flag ignored: ~s~n", [y(), r(), U]),
    parse_config_flags(R, Cfg).

%% =============================================================================
%% Flag Parsers
%% =============================================================================

parse_shorten_flags(Args) -> parse_shorten_flags(Args, #{}).
parse_shorten_flags([], Acc) -> Acc;
parse_shorten_flags(["--custom",   V | R], Acc) ->
    parse_shorten_flags(R, Acc#{custom_code => V});
parse_shorten_flags(["--ttl", V | R], Acc) ->
    case catch list_to_integer(V) of
        {'EXIT', _} ->
            io:format("  ~s!~s  --ttl must be a number, ignoring~n", [y(), r()]),
            parse_shorten_flags(R, Acc);
        N -> parse_shorten_flags(R, Acc#{ttl => N})
    end;
parse_shorten_flags(["--password", V | R], Acc) ->
    parse_shorten_flags(R, Acc#{password => V});
parse_shorten_flags(["--webhook",  V | R], Acc) ->
    parse_shorten_flags(R, Acc#{webhook_url => V});
parse_shorten_flags([U | R], Acc) ->
    io:format("  ~s!~s  Unknown flag ignored: ~s~n", [y(), r(), U]),
    parse_shorten_flags(R, Acc).

parse_page_flags(Args) -> parse_page_flags(Args, #{}).
parse_page_flags([], Acc) -> Acc;
parse_page_flags(["--page", V | R], Acc) ->
    case catch list_to_integer(V) of
        {'EXIT', _} ->
            io:format("  ~s!~s  --page must be a number~n", [y(), r()]),
            parse_page_flags(R, Acc);
        N -> parse_page_flags(R, Acc#{page => N})
    end;
parse_page_flags(["--limit", V | R], Acc) ->
    case catch list_to_integer(V) of
        {'EXIT', _} ->
            io:format("  ~s!~s  --limit must be a number~n", [y(), r()]),
            parse_page_flags(R, Acc);
        N -> parse_page_flags(R, Acc#{limit => N})
    end;
parse_page_flags([_ | R], Acc) -> parse_page_flags(R, Acc).

parse_db_flags(Args) -> parse_db_flags(Args, #{}).
parse_db_flags([], Acc) -> Acc;
parse_db_flags(["--limit", V | R], Acc) ->
    case catch list_to_integer(V) of
        {'EXIT', _} ->
            io:format("  ~s!~s  --limit must be a number~n", [y(), r()]),
            parse_db_flags(R, Acc);
        N -> parse_db_flags(R, Acc#{limit => N})
    end;
parse_db_flags(["--code", V | R], Acc) ->
    parse_db_flags(R, Acc#{code => V});
parse_db_flags([_ | R], Acc) -> parse_db_flags(R, Acc).

build_shorten_body(Url, Flags) ->
    M  = #{<<"url">> => list_to_binary(Url)},
    M1 = case maps:get(custom_code, Flags, undefined) of
             undefined -> M;
             V -> M#{<<"custom_code">> => list_to_binary(V)}
         end,
    M2 = case maps:get(ttl, Flags, undefined) of
             undefined -> M1;
             V -> M1#{<<"ttl">> => V}
         end,
    M3 = case maps:get(password, Flags, undefined) of
             undefined -> M2;
             V -> M2#{<<"password">> => list_to_binary(V)}
         end,
    M4 = case maps:get(webhook_url, Flags, undefined) of
             undefined -> M3;
             V -> M3#{<<"webhook_url">> => list_to_binary(V)}
         end,
    jsone_encode(M4).

%% =============================================================================
%% ANSI Colour Helpers
%% =============================================================================

ansi() ->
    case get(ansi) of
        undefined ->
            S = detect_ansi(),
            put(ansi, S),
            S;
        S -> S
    end.

detect_ansi() ->
    case os:getenv("NO_COLOR") of
        false -> check_terminal();
        _     -> false
    end.

check_terminal() ->
    case os:type() of
        {win32, _} ->
            os:getenv("WT_SESSION")   =/= false orelse
            os:getenv("ConEmuANSI")   =/= false orelse
            os:getenv("ANSICON")      =/= false orelse
            os:getenv("TERM_PROGRAM") =/= false orelse
            os:getenv("TERM")         =/= false;
        _ ->
            os:getenv("TERM") =/= false orelse os:getenv("COLORTERM") =/= false
    end.

col(Code) -> case ansi() of true -> Code; false -> "" end.

r()  -> col("\e[0m").
b()  -> col("\e[1m").
dm() -> col("\e[2m").
e()  -> col("\e[91m").
g()  -> col("\e[92m").
y()  -> col("\e[93m").
cy() -> col("\e[96m").

%% =============================================================================
%% Output Helpers
%% =============================================================================

ok_msg(Fmt, Args) ->
    io:format("~n  ~s✓~s  " ++ Fmt ++ "~n~n", [g(), r() | Args]).

err_msg(Msg) ->
    io:format("~n  ~s✗  Error:~s ~ts~n~n", [e(), r(), Msg]),
    halt(1).

info_msg(Fmt, Args) ->
    io:format("  ~s→~s  " ++ Fmt ++ "~n", [cy(), r() | Args]).

working(What) ->
    io:format("  ~s⋯~s  ~ts~n", [dm(), r(), lists:flatten(What)]).

base_url(#{host := H, port := P}) ->
    "http://" ++ H ++ ":" ++ integer_to_list(P).

lbl(_, null)      -> ok;
lbl(_, undefined) -> ok;
lbl(Label, Val) ->
    io:format("  ~s~-16s~s ~ts~n", [dm(), Label, r(), fmt_val(Val)]).

fmt_val(null)      -> dm() ++ "--" ++ r();
fmt_val(undefined) -> dm() ++ "--" ++ r();
fmt_val(true)      -> g()  ++ "yes" ++ r();
fmt_val(false)     -> dm() ++ "no"  ++ r();
fmt_val(B) when is_binary(B)  -> binary_to_list(B);
fmt_val(I) when is_integer(I) -> integer_to_list(I);
fmt_val(S) when is_list(S)    -> S;
fmt_val(V) -> lists:flatten(io_lib:format("~p", [V])).

pad_to(S, N) ->
    Str = if is_binary(S) -> binary_to_list(S); true -> lists:flatten(S) end,
    Len = length(Str),
    if Len >= N -> string:substr(Str, 1, N);
       true     -> Str ++ string:copies(" ", N - Len)
    end.

bin_str(B) when is_binary(B)  -> binary_to_list(B);
bin_str(S) when is_list(S)    -> lists:flatten(S);
bin_str(I) when is_integer(I) -> integer_to_list(I);
bin_str(true)  -> "yes";
bin_str(false) -> "no";
bin_str(null)  -> "--";
bin_str(_)     -> "".

truncate(B, Max) when is_binary(B) -> truncate(binary_to_list(B), Max);
truncate(S, Max) when is_list(S) ->
    F = lists:flatten(S),
    if length(F) > Max -> string:substr(F, 1, Max - 3) ++ "...";
       true            -> F
    end.

open_browser(Url) ->
    Quoted = "\"" ++ Url ++ "\"",
    case os:type() of
        {win32, _}     -> os:cmd("cmd /c start \"\" " ++ Quoted);
        {unix, darwin} -> os:cmd("open " ++ Quoted);
        {unix, _}      -> os:cmd("xdg-open " ++ Quoted);
        _              -> io:format("  Navigate to: ~s~n", [Url])
    end.

